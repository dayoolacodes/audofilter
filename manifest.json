{
  "manifest_version": 3,
  "name": "CleanMute",
  "version": "1.0.0",
  "description": "Mute and optionally censor subtitles when blocked words appear on Netflix and Prime Video.",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "*://*.netflix.com/*",
    "*://*.primevideo.com/*",
    "*://*.amazon.com/gp/video/*",
    "*://*.amazon.co.uk/gp/video/*",
    "*://*.amazon.de/gp/video/*",
    "*://*.amazon.co.jp/gp/video/*",
    "*://*.amazon.fr/gp/video/*",
    "*://*.amazon.it/gp/video/*",
    "*://*.amazon.es/gp/video/*",
    "*://*.amazon.ca/gp/video/*",
    "*://*.amazon.com.au/gp/video/*",
    "*://*.amazon.in/gp/video/*",
    "*://*.amazon.com.br/gp/video/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CleanMute"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.netflix.com/*",
        "*://*.primevideo.com/*",
        "*://*.amazon.com/gp/video/*",
        "*://*.amazon.co.uk/gp/video/*",
        "*://*.amazon.de/gp/video/*",
        "*://*.amazon.co.jp/gp/video/*",
        "*://*.amazon.fr/gp/video/*",
        "*://*.amazon.it/gp/video/*",
        "*://*.amazon.es/gp/video/*",
        "*://*.amazon.ca/gp/video/*",
        "*://*.amazon.com.au/gp/video/*",
        "*://*.amazon.in/gp/video/*",
        "*://*.amazon.com.br/gp/video/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
  ,"icons": {
    "48": "icons/icon48.png"
  }
}

{
  "manifest_version": 3,
  "name": "CleanMute",
  "version": "1.0.0",
  "description": "Automatically mutes audio when profanity appears in subtitles. Works on YouTube, Netflix, Prime Video, and any site with video subtitles.",
  "permissions": ["storage", "scripting", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "CleanMute"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
  ,"icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
